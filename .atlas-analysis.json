  "keyFeatures": [
    "Git-based autonomous AI agents with full audit trail",
    "Two-layer architecture: Next.js Event Handler + Docker Agent",
    "Free compute using GitHub Actions",
    "Self-modifying through pull requests",
    "Multi-channel chat support (Web, Telegram)",
    "Plugin system with skills",
    "Scheduled cron jobs and webhook triggers",
    "Interactive code workspaces with browser terminal",
    "Multiple LLM provider support (Anthropic, OpenAI, Google, Custom)"
